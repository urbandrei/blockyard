# Copy to .env and fill in

# Discord bot credentials (create an app + bot at https://discord.com/developers/applications)
DISCORD_BOT_TOKEN=
DISCORD_APP_ID=
DISCORD_GUILD_ID=
DISCORD_REVIEW_CHANNEL_ID=

# Server
PORT=8787
DATA_DIR=./data

# Comma-separated allowlist of origins permitted to call write routes.
# Include every platform build origin you ship to. localhost:5173 is for `npm run dev`.
ALLOWED_ORIGINS=http://localhost:5173

# Admin escape hatch for manual moderation via curl. Keep private.
ADMIN_TOKEN=

# Rate limits (can be left at defaults)
RATE_PUBLISH_PER_DAY=10
RATE_LIKE_PER_MINUTE=60
