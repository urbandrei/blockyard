# Copy to .env for local dev. Vite only exposes VITE_-prefixed vars to the
# browser bundle.

# Base URL of the community backend (`server/`) — scheme + host, no trailing
# slash. Leave empty to keep the web adapter's local-only stub behavior, e.g.
# when the tunnel is down or you're shipping a demo without a backend.
VITE_BLOCKYARD_API=

# Build target — selects the platform adapter. See vite.config.js. Defaults
# to 'web'; used by the various `build:<target>` scripts in package.json.
# PLATFORM=web

# --- Ethereum / level-ownership integration (Milestone I) ---
# The contract is a minimal ERC-721 deployed to Base Sepolia. See
# contracts/LevelRegistry.sol and contracts/README.md for deploy instructions.
# All four are required when VITE_BLOCKYARD_ETH_ENABLED=true; if it's false
# (the default), the publish flow stays signature-free and these are unused.

VITE_BLOCKYARD_ETH_ENABLED=false
VITE_BLOCKYARD_CHAIN_ID=84532
VITE_BLOCKYARD_CONTRACT_ADDRESS=
VITE_BASE_SEPOLIA_RPC=https://sepolia.base.org

# WalletConnect cloud project id. Required by RainbowKit even for injected-only
# wallets. Free tier is fine. https://cloud.walletconnect.com
VITE_WALLETCONNECT_PROJECT_ID=
