# Copy to .env and fill in. render.yaml injects DATABASE_URL automatically in production.

# Server
PORT=8787
ALLOWED_ORIGINS=http://localhost:5173

# Database — local dev example; Render sets this from the linked Postgres
DATABASE_URL=postgres://postgres:dev@localhost:5432/postgres

# Discord (see README for how to populate)
DISCORD_APP_ID=
DISCORD_PUBLIC_KEY=
DISCORD_WEBHOOK_URL=

# Admin curl escape hatch (keep private)
ADMIN_TOKEN=

# Rate limits (safe defaults)
RATE_PUBLISH_PER_DAY=10
RATE_LIKE_PER_MINUTE=60
RATE_RATING_PER_MINUTE=30
