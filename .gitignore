# Dependencies
node_modules/

# Build output
dist/
*.zip

# Foundry / contract toolchain — vendored deps (OpenZeppelin, etc.) and
# compile artifacts. These are regenerated by contracts/setup-foundry.sh
# on a fresh clone, and ship hundreds of MBs of OpenZeppelin source we
# don't author or want to track.
contracts/lib/
contracts/cache/
contracts/out/
contracts/broadcast/

# Vite cache
.vite/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Editor / OS
.DS_Store
Thumbs.db
.idea/
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
*.swp

# Env / secrets
.env
.env.*
!.env.example

# Claude Code — machine-local settings only; commit .claude/settings.json if you want shared agent config
.claude/settings.local.json

# Markdown — keep only the README public; TASKS/CLAUDE/plans/etc stay local.
# Deny-then-allowlist so README.md still gets tracked.
*.md
!README.md

